# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tecnica_db
DB_USER=dev_user
DB_PASSWORD=dev_password_123
DATABASE_URL=postgresql://dev_user:dev_password_123@postgres:5432/tecnica_db

# ========================================
# BACKEND (NestJS)
# ========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRATION=1h

# ========================================
# FRONTEND (Vue3)
# ========================================
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Prueba Técnica

# ========================================
# GOOGLE OAUTH
# ========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# ========================================
# DOCKER
# ========================================
COMPOSE_PROJECT_NAME=tecnica_fullstack

# Pasarela de pagos
# Clave maestra de cifrado de credenciales (32 bytes base64). Generar con: openssl rand -base64 32
PASARELA_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
# URL pública del backend (para el response_url de Transbank)
API_PUBLIC_URL=http://localhost:3000
