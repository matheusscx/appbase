# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=tecnica_db
DB_USER=dev_user
DB_PASSWORD=dev_password_123
DATABASE_URL=postgresql://dev_user:dev_password_123@postgres:5432/tecnica_db

# ========================================
# BACKEND (NestJS)
# ========================================
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# ========================================
# FRONTEND (Vue3)
# ========================================
VITE_API_URL=http://localhost:3000/api
VITE_APP_NAME=Prueba Técnica

# ========================================
# DOCKER
# ========================================
COMPOSE_PROJECT_NAME=tecnica_fullstack
